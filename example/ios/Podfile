ENV['RCT_NEW_ARCH_ENABLED'] = '1'

# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'BearoundReactSdkExample' do
  config = use_native_modules!

  # Dev: build against the local iOS SDK 3.0.0 source (sibling repo) instead of
  # resolving BearoundSDK ~> 3.0 from the CocoaPods trunk. Guarantees the example
  # exercises the exact local native source.
  pod 'BearoundSDK', :path => '../../../bearound-ios-sdk'

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Workaround: fmt 11.0.2 (bundled with RN 0.79) selects FMT_USE_CONSTEVAL=1
    # on modern Apple clang, but the Xcode 26 clang rejects fmt's consteval usage
    # ("call to consteval function ... is not a constant expression"). The macro
    # block in base.h is NOT #ifndef-guarded, so a -D define can't override it —
    # we patch the Apple-clang condition so it always picks 0 (constexpr path).
    fmt_base = File.join(__dir__, 'Pods/fmt/include/fmt/base.h')
    if File.exist?(fmt_base)
      src = File.read(fmt_base)
      patched = src.gsub(
        '#elif defined(__apple_build_version__) && __apple_build_version__ < 14000029L',
        '#elif defined(__apple_build_version__)'
      )
      File.write(fmt_base, patched) if patched != src
    end
  end
end
